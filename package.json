{
  "name": "kenya-brura",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx --env-file=.env.local scripts/seed.ts || tsx scripts/seed.ts",
    "db:migrate": "echo 'Apply migrations manually via Supabase SQL Editor. See supabase/migrations/ folder.'",
    "cron:daily-sync": "curl -s -X POST http://localhost:3000/api/cron/daily-sync -H 'x-cron-secret: local-dev-secret'",
    "cron:price-refresh": "curl -s -X POST http://localhost:3000/api/cron/price-refresh -H 'x-cron-secret: local-dev-secret'",
    "cron:localize": "curl -s -X POST http://localhost:3000/api/cron/localize -H 'x-cron-secret: local-dev-secret'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "@supabase/ssr": "^0.4.0",
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "openai": "^4.52.1",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/crypto-js": "^4.2.2",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
