# AliExpress Affiliate API
# Register at: https://portals.aliexpress.com/
AE_APP_KEY=
AE_APP_SECRET=
AE_TRACKING_ID=
AE_API_BASE_URL=https://api-sg.aliexpress.com/sync

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client-side - same values as above)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# Cron security secret (generate a random string)
CRON_SECRET=change-this-to-a-random-secret

# FX Exchange Rate (optional)
# If empty, uses FX_FALLBACK_RATE_ILS
FX_API_URL=
FX_FALLBACK_RATE_ILS=3.75

# OpenAI (optional - for Hebrew AI localization)
OPENAI_API_KEY=

# App URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.co.il
NEXT_PUBLIC_SITE_NAME=קנייה-ברורה
